@namespace Alife.Implement
@inherits Alife.Framework.PluginUIBase
@implements IDisposable

<div style="background: #fafafa; padding: 24px; border-radius: 12px; border: 1px solid #f0f0f0;">
    <Flex Direction="FlexDirection.Vertical" Gap="@("24")">

        <!-- 任务监控区域 -->
        <div>
            <Title Level="4" Style="margin-bottom: 16px;">时钟与定时任务监控</Title>
            @if (service != null)
            {
                <GridRow Gutter="16">
                    @foreach (var task in service.ActiveTasks)
                    {
                        var remaining = task.Time - DateTime.Now;
                        var isFinished = remaining.TotalSeconds <= 0;
                        var isPermanent = task.Time == DateTime.MaxValue;

                        <GridCol Span="12" Style="margin-bottom: 16px;">
                            <Card Size="CardSize.Small"
                                  Style="border-radius: 8px; border: 1px solid #e8e8e8; background: #fff;">
                                <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center">
                                    <div style="flex: 1;">
                                        <Text Strong
                                              Style="font-size: 14px; display: block; margin-bottom: 4px;">@task.Name</Text>
                                        @if (isPermanent)
                                        {
                                            <Badge Status="BadgeStatus.Default" Text="待机中"/>
                                        }
                                        else if (isFinished)
                                        {
                                            <Badge Status="BadgeStatus.Processing" Color="BadgeColor.Green"
                                                   Text="即将触发..."/>
                                        }
                                        else
                                        {
                                            <Badge Status="BadgeStatus.Processing" Color="BadgeColor.Blue"
                                                   Text="@FormatRemaining(remaining)"/>
                                        }
                                    </div>
                                    <Icon Type="clock-circle" Theme="IconThemeType.Outline"
                                          Style="font-size: 20px; color: #bfbfbf;"/>
                                </Flex>
                                <div
                                    style="margin-top: 12px; font-size: 12px; color: #8c8c8c; border-top: 1px solid #f5f5f5; padding-top: 8px;">
                                    设定时间: @(isPermanent ? "无" : task.Time.ToString("HH:mm:ss"))
                                </div>
                            </Card>
                        </GridCol>
                    }
                </GridRow>
            }
            else
            {
                <Alert Type="AlertType.Warning" Message="无法连接到运行中的事件服务喵！" ShowIcon="true"/>
            }
        </div>

        @if (service?.Configuration != null)
        {
            <Divider Style="margin: 8px 0;"/>

            <!-- 配置参数区域 -->
            <div>
                <Title Level="4" Style="margin-bottom: 16px;">配置参数</Title>
                <GridRow Gutter="16">
                    <GridCol Span="12">
                        <div style="margin-bottom: 16px;">
                            <Text Type="TextElementType.Secondary" Style="display: block; margin-bottom: 8px;">报点基础间隔
                                (秒)
                            </Text>
                            <InputNumber @bind-Value="@service.Configuration.UpdateInterval" Min="1"
                                         Style="width: 100%; border-radius: 6px;"/>
                        </div>
                    </GridCol>
                    <GridCol Span="12">
                        <div style="margin-bottom: 16px;">
                            <Text Type=TextElementType.Secondary Style="display: block; margin-bottom: 8px;">随机偏移范围
                                (秒)
                            </Text>
                            <InputNumber @bind-Value="@service.Configuration.UpdateRandomOffset" Min="0"
                                         Style="width: 100%; border-radius: 6px;"/>
                        </div>
                    </GridCol>

                    <GridCol Span="24">
                        <div style="margin-bottom: 16px;">
                            <Text Type=TextElementType.Secondary Style="display: block; margin-bottom: 8px;">
                                程序启动附加提示
                            </Text>
                            <TextArea @bind-Value="@service.Configuration.AppendStartPrompt" Rows="2"
                                      Placeholder="例如：'今天是重要的一天喵！'" Style="border-radius: 6px;"></TextArea>
                        </div>
                    </GridCol>

                    <GridCol Span="24">
                        <div style="margin-bottom: 16px;">
                            <Text Type=TextElementType.Secondary Style="display: block; margin-bottom: 8px;">
                                自动报点附加提示
                            </Text>
                            <TextArea @bind-Value="@service.Configuration.AppendUpdatePrompt" Rows="2"
                                      Placeholder="赋予AI报点时的特殊指令或背景..."
                                      Style="border-radius: 6px;"></TextArea>
                        </div>
                    </GridCol>

                    <GridCol Span="24">
                        <div style="margin-bottom: 8px;">
                            <Text Type=TextElementType.Secondary Style="display: block; margin-bottom: 8px;">
                                程序关闭附加提示
                            </Text>
                            <TextArea @bind-Value="@service.Configuration.AppendDestroyPrompt" Rows="2"
                                      Placeholder="临别赠言..." Style="border-radius: 6px;"></TextArea>
                        </div>
                    </GridCol>
                </GridRow>
            </div>
        }

    </Flex>
</div>

@code {
    EventService? service;
    private System.Timers.Timer? refreshTimer;

    protected override void OnInitialized()
    {
        refreshTimer = new System.Timers.Timer(1000);
        refreshTimer.Elapsed += (_, _) => InvokeAsync(StateHasChanged);
        refreshTimer.Start();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        service = Plugin as EventService;
    }

    private string FormatRemaining(TimeSpan ts)
    {
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours}h {ts.Minutes}m {ts.Seconds}s";
        if (ts.TotalMinutes >= 1) return $"{(int)ts.TotalMinutes}m {ts.Seconds}s";
        return $"{(int)ts.TotalSeconds}s";
    }

    public void Dispose()
    {
        refreshTimer?.Stop();
        refreshTimer?.Dispose();
    }
}
