@inherits LayoutComponentBase
@inject CharacterSystem CharacterSystem
@inject ChatActivitySystem ChatActivitySystem
@inject FragmentService FragmentService

<div class="app-container">
    <!-- 第一层 Sider: 全局主导航 -->
    <div class="global-sidebar" style="width: 80px; flex-shrink: 0; padding-top: 24px;">
        <NavMenu/>
    </div>

    <!-- 主内容区 -->
    <div class="main-content">
        @Body
    </div>
</div>

<Modal Visible="@isAutoStarting"
       Title="@("正在唤醒自动启动的角色...")"
       Footer="null"
       Closable="false"
       MaskClosable="false"
       Centered="true">
    <Flex Direction="@FlexDirection.Vertical" Align="@FlexAlign.Center"
          Gap="@FlexGap.Large">
        <Spin Size="@SpinSize.Large" Tip="正在初始化环境，请稍候喵..."/>
        <Text Type="@TextElementType.Secondary">涉及模型加载与记忆恢复，请勿关闭应用</Text>
    </Flex>
</Modal>

<AntContainer/>

@code {
    static bool hasAutoStarted = false;
    bool isAutoStarting = false;

    protected override async Task OnInitializedAsync()
    {
        if (hasAutoStarted) return;
        hasAutoStarted = true;

        //角色自启动
        var startingCharacters = CharacterSystem.GetAllCharacters().Where(c => c.AutoActivate && !ChatActivitySystem.IsActivated(c)).ToList();
        if (startingCharacters.Any())
        {
            isAutoStarting = true;
            StateHasChanged();

            foreach (Character character in startingCharacters)
            {
                try
                {
                    await ChatActivitySystem.Play(character);
                }
                catch (Exception e)
                {
                    FragmentService.ShowException($"{character.Name} 自启失败喵！", e);
                }
            }

            isAutoStarting = false;
            StateHasChanged();
        }
    }
}